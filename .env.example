# Deep Dive — local environment variables
# Copy this file to .env and fill in the values. Never commit .env to git.

# Required for analytics + photo URLs (Supabase)
# Get both from: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase

# Optional — Ghost Diver AI chat (dev only; do not use in production)
# Get from: https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=sk-...

# Optional — webhook for notifications (e.g. Slack/Discord)
# VITE_NOTIFY_WEBHOOK=https://hooks.slack.com/...
